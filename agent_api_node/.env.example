# Agent API (Node/Fastify)
PORT=8080
HOST=0.0.0.0

# Gateway: Backend Flask upstream (para rotas /api/* que não sejam /api/agent/*)
UPSTREAM_FLASK_URL=https://web-production-43563.up.railway.app

# PostgreSQL
DATABASE_URL=postgres://user:password@host:port/dbname
# (opcional) preferir conexão direta se tiver pooler/pgbouncer
DIRECT_URL=

# Segurança: se vazio, permite acesso sem chave (modo dev)
AGENT_API_KEY=

# Ajustes de pool
PG_POOL_MAX=20
PG_POOL_IDLE_MS=30000
PG_POOL_CONN_TIMEOUT_MS=10000

# Limite do body (bytes) – dashboards podem ser grandes
BODY_LIMIT_BYTES=20971520
