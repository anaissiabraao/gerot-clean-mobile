# ============================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/gerot_tms

# ============================================
# AUTENTICAÇÃO JWT
# ============================================
JWT_SECRET=sua-chave-secreta-jwt-super-segura-aqui-minimo-32-caracteres
JWT_REFRESH_SECRET=sua-chave-secreta-refresh-token-super-segura-aqui-minimo-32-caracteres
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CERTIFICADO DIGITAL SEFAZ (A1 - PFX)
# ============================================
SEFAZ_CERT_PATH=./certs/certificado.pfx
SEFAZ_CERT_PASSWORD=sua-senha-do-certificado
SEFAZ_AMBIENTE=homologacao
# Opções: homologacao | producao

# ============================================
# CONFIGURAÇÕES SEFAZ
# ============================================
SEFAZ_UF=SP
SEFAZ_CNPJ=12345678000190
SEFAZ_RAZAO_SOCIAL=VCI TRANSPORTES LTDA
SEFAZ_IE=123456789012

# URLs SEFAZ (homologação)
SEFAZ_CTE_URL_HOMOLOGACAO=https://homologacao.nfe.fazenda.sp.gov.br/cteweb/services/CteRecepcao.asmx
SEFAZ_CTE_URL_CONSULTA_HOMOLOGACAO=https://homologacao.nfe.fazenda.sp.gov.br/cteweb/services/CteConsulta.asmx
SEFAZ_MDFE_URL_HOMOLOGACAO=https://homologacao.mdfe.fazenda.sp.gov.br/MDFeWS/services/MDFeRecepcao.asmx
SEFAZ_MDFE_URL_CONSULTA_HOMOLOGACAO=https://homologacao.mdfe.fazenda.sp.gov.br/MDFeWS/services/MDFeConsulta.asmx

# URLs SEFAZ (produção)
SEFAZ_CTE_URL_PRODUCAO=https://nfe.fazenda.sp.gov.br/cteweb/services/CteRecepcao.asmx
SEFAZ_CTE_URL_CONSULTA_PRODUCAO=https://nfe.fazenda.sp.gov.br/cteweb/services/CteConsulta.asmx
SEFAZ_MDFE_URL_PRODUCAO=https://mdfe.fazenda.sp.gov.br/MDFeWS/services/MDFeRecepcao.asmx
SEFAZ_MDFE_URL_CONSULTA_PRODUCAO=https://mdfe.fazenda.sp.gov.br/MDFeWS/services/MDFeConsulta.asmx

# ============================================
# CONFIGURAÇÕES SMTP (ENVIO DE EMAIL)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app
SMTP_FROM_NAME=VCI TRANSPORTES
SMTP_FROM_EMAIL=noreply@vcitransportes.com.br

# ============================================
# CONFIGURAÇÕES BOLETO (BANCOS)
# ============================================
BOLETO_BANCO=001
# 001 = Banco do Brasil
# 341 = Itaú
# 077 = Inter

BOLETO_CEDENTE_CNPJ=12345678000190
BOLETO_CEDENTE_NOME=VCI TRANSPORTES LTDA
BOLETO_CEDENTE_AGENCIA=1234
BOLETO_CEDENTE_CONTA=12345-6
BOLETO_CEDENTE_DIGITO=6

# ============================================
# SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3000

# ============================================
# CHAVES DE API PARA INTELIGÊNCIA ARTIFICIAL (Opcional)
# ============================================
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ============================================
# INTEGRAÇÃO PLANNER (Opcional)
# ============================================
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_PLANNER_PLAN_ID=
MS_PLANNER_BUCKET_ID=
