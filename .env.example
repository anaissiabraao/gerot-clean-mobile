# -----------------------------------------------------------------------------
# Front (Vite/React na raiz – Lovable)
# -----------------------------------------------------------------------------
VITE_BACKEND_URL=http://localhost:5000
VITE_API_BASE_URL=
VITE_HEALTH_ENDPOINT=/api/agent/health
VITE_REQUEST_TIMEOUT_MS=10000
VITE_REDIRECT_TO_BACKEND_LOGIN=false

# -----------------------------------------------------------------------------
# Backend (Flask)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@host:port/dbname

# Migração Supabase → Railway: origem (Supabase) e destino (Railway = DATABASE_URL acima)
# SUPABASE_DATABASE_URL=postgres://postgres.[ref]:[senha]@aws-0-[regiao].pooler.supabase.com:5432/postgres

# Chaves de API para Inteligência Artificial
# OpenAI (DALL-E, GPT-4) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini (Fallback e Chat Gratuito) - https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Configurações de Segurança
SECRET_KEY=sua-chave-secreta-aqui

# Integração Planner (Opcional)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_PLANNER_PLAN_ID=
MS_PLANNER_BUCKET_ID=
